# Local config — DB credentials never go into git.
includes/config.php

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Server-generated rsync log
last-deploy.log

# User-uploaded files live in uploads/student_docs/ on the server.
# Track the directory structure + .htaccess + .gitkeep but never the
# actual uploads.
uploads/student_docs/*
!uploads/student_docs/.gitkeep
uploads/receipts/*
!uploads/receipts/.gitkeep
